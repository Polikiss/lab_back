# На Railway/Render скопируйте все переменные в Environment (файл .env в репо не деплоится).
EVM_RPC_URL=https://eth-rpc-testnet.polkadot.io/
EVM_CHAIN_ID=420420417
VOTE_TOKEN_ADDRESS=0xB3261862181dA73c029D8072c947A9CC8631a59f
CONFIRMATIONS=1

STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_ORACLE_SECRET=S...
# Опционально: имя identity из `stellar keys` — как --source в CLI (перекрывает секрет из .env)
# STELLAR_ORACLE_SOURCE=stasao1
STELLAR_WRAPPER_CONTRACT_ID=CC76GB4WIXVIXGCC7X7R2SERJQIXWJJSAZMBGU7PAPGGCSGSEC6POQ5P

# EVM → Stellar: mint = floor(locked_amount / divisor). По умолчанию 100_000 (1e-10 ETH → 1000 mint). Без масштаба: 1
# EVM_TO_STELLAR_AMOUNT_DIVISOR=100000

PORT=8080

# Двусторонний мост: Stellar → EVM (ProbeBridgeToken.mintFromStellar)
# Owner токена: setBridgeMinter(<адрес из ORACLE_EVM_PRIVATE_KEY>)
# Выключить обратное направление: REVERSE_EVM_MINT_ENABLED=false
# POST /mint-from-stellar: amount в целых/дробных токенах (1 = 1 wpro). Сырой wei: REVERSE_MINT_AMOUNT_IN_WEI=true
# ORACLE_EVM_PRIVATE_KEY=0x...

# Опционально: после mint на Stellar оракул вызывает BridgeVoteCredit на EVM
# (нужен кошелёк оракула с PAS на Polkadot testnet)
# BRIDGE_VOTE_CREDIT_ADDRESS=0x...
